# =====================
# Django Configuration
# =====================
FRONTEND_URL=http://localhost:8080
DOMAIN=http://localhost:8080
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
USE_S3=FALSE
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
DJANGO_SECRET_KEY="your-secret-key-here"

# =====================
# OpenSearch
# =====================
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200

# =====================
# Stripe (テスト用)
# =====================
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_PRICE_ID_LIGHT="price_your_light_price_id"
STRIPE_PRICE_ID_PREMIUM="price_your_premium_price_id"
STRIPE_PRODUCT_ID_LIGHT="prod_your_light_product_id"
STRIPE_PRODUCT_ID_PREMIUM="prod_your_premium_product_id"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# =====================
# Redis / Celery
# =====================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =====================
# Database
# =====================
USE_AWS_RDS=FALSE
# --- docker-composeのPostgreSQLを使う場合 ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=videoq
POSTGRES_PASSWORD=your_postgres_password

# =====================
# Mailgun
# =====================
USE_MAILGUN=FALSE

# =====================
# Vector Search Provider
# =====================
# opensearch または pinecone を選択
VECTOR_SEARCH_PROVIDER=opensearch

# =====================
# Pinecone (VECTOR_SEARCH_PROVIDER=pinecone の場合)
# =====================
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# =====================
# OpenSearch Docker
# =====================
DISCOVERY_TYPE=single-node
BOOTSTRAP_MEMORY_LOCK=true
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
DISABLE_INSTALL_DEMO_CONFIG=true
DISABLE_SECURITY_PLUGIN=true

# OpenSearch Dashboards
OPENSEARCH_HOSTS=["http://opensearch:9200"]
DISABLE_SECURITY_DASHBOARDS_PLUGIN=true

# Basic認証
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=your_basic_auth_password

# =====================
# Cloudflare Tunnel
# =====================
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token 